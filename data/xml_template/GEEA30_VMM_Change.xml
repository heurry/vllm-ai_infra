<?xml version="1.0"?>
<TaskNode xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:xsd="http://www.w3.org/2001/XMLSchema" ID="0">
	<MainNodes>
		<MainNode ID="0">
			<AnnNode ID="0">
				<CVNodes>
					<CreateVarNode ID="0" Name="SourceAddress" Type="Bytes" VarDefaultValue="Bytes.Empty" />
					<CreateVarNode ID="1" Name="ECUAddress" Type="Bytes" VarDefaultValue="Bytes.Empty" />
					<CreateVarNode ID="2" Name="Status" Type="EnumRVAgentStatus" VarDefaultValue="EnumRVAgentStatus.WaitSend" />
					<CreateVarNode ID="3" Name="ResponseByteData" Type="Bytes" VarDefaultValue="Bytes.Empty" />
					<CreateVarNode ID="4" Name="EcuBOMName" Type="string" VarDefaultValue="string.Empty" />
					<CreateVarNode ID="5" Name="Seed" Type="Bytes" VarDefaultValue="Bytes.Empty" />
					<CreateVarNode ID="6" Name="SeedKey" Type="Bytes" VarDefaultValue="Bytes.Empty" />
					<CreateVarNode ID="7" Name="L3DefaultSecurityValue" Type="Bytes" VarDefaultValue="Bytes.Empty" />
					<CreateVarNode ID="8" Name="RetryCount" Type="int" VarDefaultValue="0" />
					<CreateVarNode ID="9" Name="DID" Type="Bytes" VarDefaultValue="Bytes.Empty" />
					<CreateVarNode ID="10" Name="RequestParameter" Type="Bytes" VarDefaultValue="Bytes.Empty" />
					<CreateVarNode ID="11" Name="IOErrorVCode" Type="string" VarDefaultValue="string.Empty" />
					<CreateVarNode ID="12" Name="ReadErrorVCode" Type="string" VarDefaultValue="string.Empty" />
					<CreateVarNode ID="13" Name="Position" Type="string" VarDefaultValue="string.Empty" />
					<CreateVarNode ID="14" Name="Message" Type="string" VarDefaultValue="string.Empty" />
				</CVNodes>
			</AnnNode>

			<FlowsNodes>
				<!-- Initial -->
				<NormalBoxNode ID="1" GotoCatchError="-1" Goto="2">
					<OptNodes>
						<AssignNode ID="0" LeftVar="SourceAddress" RightExpression="Bytes.Parse(_argLibrary.Get(&quot;SourceAddress&quot;))" />
						<AssignNode ID="1" LeftVar="ECUAddress" RightExpression="Bytes.Parse(_argLibrary.Get(&quot;ECUAddress&quot;))" />
						<AssignNode ID="2" LeftVar="EcuBOMName" RightExpression="_argLibrary.Get(&quot;EcuBOMName&quot;)" />
						<AssignNode ID="3" LeftVar="L3DefaultSecurityValue" RightExpression="Bytes.Parse(_argLibrary.Get(&quot;L3DefaultSecurityValue&quot;))" />
						<AssignNode ID="4" LeftVar="RetryCount" RightExpression="3" />
						<AssignNode ID="5" LeftVar="DID" RightExpression="Bytes.Parse(_argLibrary.Get(&quot;DID&quot;))" />
						<AssignNode ID="6" LeftVar="RequestParameter" RightExpression="Bytes.Parse(_argLibrary.Get(&quot;RequestParameter&quot;))" />
						<AssignNode ID="7" LeftVar="RetryCount" RightExpression="3" />
						<AssignNode ID="8" LeftVar="IOErrorVCode" RightExpression="_argLibrary.Get(&quot;IOErrorVCode&quot;)" />
						<AssignNode ID="9" LeftVar="ReadErrorVCode" RightExpression="_argLibrary.Get(&quot;ReadErrorVCode&quot;)" />
						<AssignNode ID="10" LeftVar="Position" RightExpression="_argLibrary.Get(&quot;Position&quot;)" />
						<AssignNode ID="11" LeftVar="Message" RightExpression="_argLibrary.Get(&quot;Message&quot;)" />
					</OptNodes>
				</NormalBoxNode>
				<NormalBoxNode ID="2" GotoCatchError="-1" Goto="10">
					<GotoPairs>
						<GotoPair>
							<Expression>!string.IsNullOrEmpty(Position) &amp;&amp; !string.IsNullOrEmpty(Message)</Expression>
							<Goto>3</Goto>
						</GotoPair>
					</GotoPairs>
				</NormalBoxNode>
				<NormalBoxNode ID="3" GotoCatchError="-1" Goto="10">
					<OptNodes>
						<CallFunctionNode ID="1" FunctionName="htmlPageLibrary.SetValue">
							<InputVars>
								<Param Name="key">Position</Param>
								<Param Name="value">Message</Param>
							</InputVars>
						</CallFunctionNode>
					</OptNodes>
				</NormalBoxNode>

				<!-- Enter Ext-Session -->
				<NormalBoxNode ID="10" GotoCatchError="-1" Goto="11">
					<OptNodes>
						<CallFunctionNode ID="1" FunctionName="_udsLibrary.SendUDSRawData">
							<InputVars>
								<Param>Bytes.Concat(SourceAddress,ECUAddress,Bytes.Parse(&quot;0x1003&quot;))</Param>
							</InputVars>
						</CallFunctionNode>
					</OptNodes>
				</NormalBoxNode>
				<NormalBoxNode ID="11" GotoCatchError="-1" Goto="12">
					<OptNodes>
						<CallFunctionNode ID="0" RevResultVar="Status" FunctionName="_udsLibrary.ReadStatus" />
					</OptNodes>
					<GotoPairs>
						<GotoPair>
							<Expression>Status == EnumRVAgentStatus.NAck</Expression>
							<Goto>99991</Goto>
						</GotoPair>
						<GotoPair>
							<Expression>Status == EnumRVAgentStatus.ResponseTimeout</Expression>
							<Goto>99992</Goto>
						</GotoPair>
						<GotoPair>
							<Expression>Status != EnumRVAgentStatus.GotResponse</Expression>
							<Goto>15</Goto>
						</GotoPair>
					</GotoPairs>
				</NormalBoxNode>
				<NormalBoxNode ID="12" GotoCatchError="-1" Goto="15">
					<OptNodes>
						<CallFunctionNode ID="0" RevResultVar="ResponseByteData" FunctionName="_udsLibrary.ReadUDSData" />
					</OptNodes>
					<GotoPairs>
						<GotoPair>
							<Expression>ResponseByteData.Count &gt;= 2 &amp;&amp;
								ResponseByteData.Slice(0,2).SequenceEqual(Bytes.Parse("0x5003"))</Expression>
							<Goto>20</Goto>
						</GotoPair>
					</GotoPairs>
				</NormalBoxNode>
				<NormalBoxNode ID="15" GotoCatchError="-1" Goto="-1">
					<OptNodes>
						<CallFunctionNode ID="0" FunctionName="errorLibrary.SetFault">
							<InputVars>
								<Param>EcuBOMName</Param>
								<Param>"V31003"</Param>
							</InputVars>
						</CallFunctionNode>
					</OptNodes>
				</NormalBoxNode>

				<NormalBoxNode ID="20" GotoCatchError="-1" Goto="21">
					<OptNodes>
						<CallFunctionNode ID="0" FunctionName="_udsLibrary.SendUDSRawData">
							<InputVars>
								<Param>Bytes.Concat(SourceAddress,ECUAddress,Bytes.Concat(Bytes.Parse(&quot;0x22&quot;),DID))</Param>
							</InputVars>
						</CallFunctionNode>
					</OptNodes>
				</NormalBoxNode>
				<NormalBoxNode ID="21" GotoCatchError="-1" Goto="22">
					<OptNodes>
						<CallFunctionNode ID="0" RevResultVar="Status" FunctionName="_udsLibrary.ReadStatus" />
					</OptNodes>
					<GotoPairs>
						<GotoPair>
							<Expression>Status == EnumRVAgentStatus.NAck</Expression>
							<Goto>99991</Goto>
						</GotoPair>
						<GotoPair>
							<Expression>Status == EnumRVAgentStatus.ResponseTimeout</Expression>
							<Goto>99992</Goto>
						</GotoPair>
						<GotoPair>
							<Expression>Status != EnumRVAgentStatus.GotResponse</Expression>
							<Goto>25</Goto>
						</GotoPair>
					</GotoPairs>
				</NormalBoxNode>
				<NormalBoxNode ID="22" GotoCatchError="-1" Goto="25">
					<OptNodes>
						<CallFunctionNode ID="0" RevResultVar="ResponseByteData" FunctionName="_udsLibrary.ReadUDSData" />
					</OptNodes>
					<GotoPairs>
						<GotoPair>
							<Expression>
								ResponseByteData.Count &gt;=4 &amp;&amp;
								ResponseByteData.Slice(0,3).SequenceEqual(Bytes.Concat(Bytes.Parse(&quot;0x62&quot;),DID))</Expression>
							<Goto>26</Goto>
						</GotoPair>
					</GotoPairs>
				</NormalBoxNode>
				<NormalBoxNode ID="25" GotoCatchError="-1" Goto="-1">
					<OptNodes>
						<CallFunctionNode ID="0" FunctionName="errorLibrary.SetFault">
							<InputVars>
								<Param>EcuBOMName</Param>
								<Param>ReadErrorVCode</Param>
							</InputVars>
						</CallFunctionNode>
					</OptNodes>
				</NormalBoxNode>
				<NormalBoxNode ID="26" GotoCatchError="-1" Goto="30">
					<GotoPairs>
						<GotoPair>
							<Expression>ResponseByteData.Slice(3).SequenceEqual(RequestParameter)</Expression>
							<Goto>0</Goto>
						</GotoPair>
					</GotoPairs>
				</NormalBoxNode>

				<!--  Security Access Level03 -->
				<NormalBoxNode ID="30" GotoCatchError="-1" Goto="31">
					<OptNodes>
						<CallFunctionNode ID="0" FunctionName="_udsLibrary.SendUDSRawData">
							<InputVars>
								<Param>Bytes.Concat(SourceAddress,ECUAddress,Bytes.Parse(&quot;0x2703&quot;))</Param>
							</InputVars>
						</CallFunctionNode>
					</OptNodes>
				</NormalBoxNode>
				<NormalBoxNode ID="31" GotoCatchError="-1" Goto="32">
					<OptNodes>
						<CallFunctionNode ID="0" RevResultVar="Status" FunctionName="_udsLibrary.ReadStatus">
						</CallFunctionNode>
					</OptNodes>
				</NormalBoxNode>
				<NormalBoxNode ID="32" GotoCatchError="-1" Goto="33">
					<GotoPairs>
						<GotoPair>
							<Expression>Status == EnumRVAgentStatus.NAck</Expression>
							<Goto>99991</Goto>
						</GotoPair>
						<GotoPair>
							<Expression>Status == EnumRVAgentStatus.ResponseTimeout</Expression>
							<Goto>99992</Goto>
						</GotoPair>
						<GotoPair>
							<Expression>Status != EnumRVAgentStatus.GotResponse</Expression>
							<Goto>35</Goto>
						</GotoPair>
					</GotoPairs>
				</NormalBoxNode>
				<NormalBoxNode ID="33" GotoCatchError="-1" Goto="35">
					<OptNodes>
						<CallFunctionNode ID="0" RevResultVar="ResponseByteData" FunctionName="_udsLibrary.ReadUDSData" />
					</OptNodes>
					<GotoPairs>
						<GotoPair>
							<Expression>
								ResponseByteData.Count &gt;= 2 &amp;&amp;
								ResponseByteData.Slice(0,2).SequenceEqual(Bytes.Parse("0x6703"))</Expression>
							<Goto>36</Goto>
						</GotoPair>
					</GotoPairs>
				</NormalBoxNode>
				<NormalBoxNode ID="35" GotoCatchError="-1" Goto="-1">
					<OptNodes>
						<CallFunctionNode ID="0" FunctionName="errorLibrary.SetFault">
							<InputVars>
								<Param>EcuBOMName</Param>
								<Param>"V32703"</Param>
							</InputVars>
						</CallFunctionNode>
					</OptNodes>
				</NormalBoxNode>
				<NormalBoxNode ID="36" GotoCatchError="-1" Goto="40">
					<OptNodes>
						<AssignNode ID="0" LeftVar="Seed" RightExpression="ResponseByteData.Slice(2)" />
					</OptNodes>
				</NormalBoxNode>

				<!-- Use Default SecurityMask -->
				<NormalBoxNode ID="40" GotoCatchError="-1" Goto="41">
					<OptNodes>
						<CallFunctionNode ID="0" FunctionName="saLibrary.GenerateKey" RevResultVar="SeedKey">
							<InputVars>
								<Param Name="seed">Seed</Param>
								<Param Name="pincode">L3DefaultSecurityValue</Param>
							</InputVars>
						</CallFunctionNode>
					</OptNodes>
				</NormalBoxNode>
				<!-- Security Access -->
				<NormalBoxNode ID="41" GotoCatchError="-1" Goto="42">
					<OptNodes>
						<CallFunctionNode ID="0" FunctionName="_udsLibrary.SendUDSRawData">
							<InputVars>
								<Param>Bytes.Concat(SourceAddress,ECUAddress,Bytes.Parse(&quot;0x2704&quot;),SeedKey)</Param>
							</InputVars>
						</CallFunctionNode>
					</OptNodes>
				</NormalBoxNode>
				<NormalBoxNode ID="42" GotoCatchError="-1" Goto="43">
					<OptNodes>
						<CallFunctionNode ID="0" RevResultVar="Status" FunctionName="_udsLibrary.ReadStatus">
						</CallFunctionNode>
					</OptNodes>
				</NormalBoxNode>
				<NormalBoxNode ID="43" GotoCatchError="-1" Goto="44">
					<GotoPairs>
						<GotoPair>
							<Expression>Status == EnumRVAgentStatus.NAck</Expression>
							<Goto>99991</Goto>
						</GotoPair>
						<GotoPair>
							<Expression>Status == EnumRVAgentStatus.ResponseTimeout</Expression>
							<Goto>99992</Goto>
						</GotoPair>
						<GotoPair>
							<Expression>Status != EnumRVAgentStatus.GotResponse</Expression>
							<Goto>55</Goto>
						</GotoPair>
					</GotoPairs>
				</NormalBoxNode>
				<NormalBoxNode ID="44" GotoCatchError="-1" Goto="55">
					<OptNodes>
						<CallFunctionNode ID="0" FunctionName="_udsLibrary.ReadUDSData" RevResultVar="ResponseByteData" />
					</OptNodes>
					<GotoPairs>
						<GotoPair>
							<Expression>ResponseByteData.Count &gt;= 2 &amp;&amp;
								ResponseByteData.Slice(0,2).SequenceEqual(Bytes.Parse("0x6704"))</Expression>
							<Goto>60</Goto>
						</GotoPair>
					</GotoPairs>
				</NormalBoxNode>
				<NormalBoxNode ID="55" GotoCatchError="-1" Goto="-1">
					<OptNodes>
						<CallFunctionNode ID="0" FunctionName="errorLibrary.SetFault">
							<InputVars>
								<Param>EcuBOMName</Param>
								<Param>"V32704"</Param>
							</InputVars>
						</CallFunctionNode>
					</OptNodes>
				</NormalBoxNode>

				<!-- Start IO Control -->
				<NormalBoxNode ID="60" GotoCatchError="-1" Goto="61">
					<OptNodes>
						<CallFunctionNode ID="0" FunctionName="_udsLibrary.SendUDSRawData">
							<InputVars>
								<Param>Bytes.Concat(SourceAddress,ECUAddress,Bytes.Concat(Bytes.Parse(&quot;0x2F&quot;),DID,Bytes.Parse(&quot;0x03&quot;),RequestParameter))</Param>
							</InputVars>
						</CallFunctionNode>
					</OptNodes>
				</NormalBoxNode>
				<NormalBoxNode ID="61" GotoCatchError="-1" Goto="62">
					<OptNodes>
						<CallFunctionNode ID="0" RevResultVar="Status" FunctionName="_udsLibrary.ReadStatus" />
					</OptNodes>
				</NormalBoxNode>
				<NormalBoxNode ID="62" GotoCatchError="-1" Goto="63">
					<GotoPairs>
						<GotoPair>
							<Expression>Status == EnumRVAgentStatus.NAck</Expression>
							<Goto>99991</Goto>
						</GotoPair>
						<GotoPair>
							<Expression>Status == EnumRVAgentStatus.ResponseTimeout</Expression>
							<Goto>99992</Goto>
						</GotoPair>
						<GotoPair>
							<Expression>Status != EnumRVAgentStatus.GotResponse</Expression>
							<Goto>75</Goto>
						</GotoPair>
					</GotoPairs>
				</NormalBoxNode>
				<NormalBoxNode ID="63" GotoCatchError="-1" Goto="64">
					<OptNodes>
						<CallFunctionNode ID="0" RevResultVar="ResponseByteData" FunctionName="_udsLibrary.ReadUDSData" />
					</OptNodes>
					<GotoPairs>
						<GotoPair>
							<Expression>
								ResponseByteData.Count &gt;=5 &amp;&amp;
								ResponseByteData.Slice(0,5).SequenceEqual(Bytes.Concat(Bytes.Parse(&quot;0x6F&quot;),DID,Bytes.Parse(&quot;0x03&quot;),RequestParameter))</Expression>
							<Goto>80</Goto>
						</GotoPair>
					</GotoPairs>
				</NormalBoxNode>
				<NormalBoxNode ID="64" GotoCatchError="-1" Goto="75">
					<GotoPairs>
						<GotoPair>
							<Expression>RetryCount &gt; 0</Expression>
							<Goto>65</Goto>
						</GotoPair>
					</GotoPairs>
				</NormalBoxNode>
				<NormalBoxNode ID="65" GotoCatchError="-1" Goto="60">
					<OptNodes>
						<AssignNode ID="0" LeftVar="RetryCount" RightExpression="RetryCount-1" />
					</OptNodes>
				</NormalBoxNode>
				<NormalBoxNode ID="75" GotoCatchError="-1" Goto="-1">
					<OptNodes>
						<CallFunctionNode ID="0" FunctionName="errorLibrary.SetFault">
							<InputVars>
								<Param>EcuBOMName</Param>
								<Param>IOErrorVCode</Param>
							</InputVars>
						</CallFunctionNode>
					</OptNodes>
				</NormalBoxNode>

				<!-- Read Result -->
				<NormalBoxNode ID="80" GotoCatchError="-1" Goto="81">
					<OptNodes>
						<AssignNode ID="0" LeftVar="RetryCount" RightExpression="3" />
					</OptNodes>
				</NormalBoxNode>
				<NormalBoxNode ID="81" GotoCatchError="-1" Goto="82">
					<OptNodes>
						<CallFunctionNode ID="0" FunctionName="_udsLibrary.SendUDSRawData">
							<InputVars>
								<Param>
									Bytes.Concat(SourceAddress,ECUAddress,Bytes.Concat(Bytes.Parse(&quot;0x22&quot;),DID))</Param>
							</InputVars>
						</CallFunctionNode>
					</OptNodes>
				</NormalBoxNode>
				<NormalBoxNode ID="82" GotoCatchError="-1" Goto="83">
					<OptNodes>
						<CallFunctionNode ID="0" RevResultVar="Status" FunctionName="_udsLibrary.ReadStatus" />
					</OptNodes>
				</NormalBoxNode>
				<NormalBoxNode ID="83" GotoCatchError="-1" Goto="84">
					<GotoPairs>
						<GotoPair>
							<Expression>Status == EnumRVAgentStatus.NAck</Expression>
							<Goto>99991</Goto>
						</GotoPair>
						<GotoPair>
							<Expression>Status == EnumRVAgentStatus.ResponseTimeout</Expression>
							<Goto>99992</Goto>
						</GotoPair>
						<GotoPair>
							<Expression>Status != EnumRVAgentStatus.GotResponse</Expression>
							<Goto>95</Goto>
						</GotoPair>
					</GotoPairs>
				</NormalBoxNode>
				<NormalBoxNode ID="84" GotoCatchError="-1" Goto="85">
					<OptNodes>
						<CallFunctionNode ID="0" RevResultVar="ResponseByteData" FunctionName="_udsLibrary.ReadUDSData" />
					</OptNodes>
					<GotoPairs>
						<GotoPair>
							<Expression>
								ResponseByteData.Count &gt;=4 &amp;&amp;
								ResponseByteData.Slice(0,3).SequenceEqual(Bytes.Concat(Bytes.Parse(&quot;0x62&quot;),DID))</Expression>
							<Goto>90</Goto>
						</GotoPair>
					</GotoPairs>
				</NormalBoxNode>
				<NormalBoxNode ID="85" GotoCatchError="-1" Goto="95">
					<GotoPairs>
						<GotoPair>
							<Expression>
								RetryCount &gt; 0</Expression>
							<Goto>86</Goto>
						</GotoPair>
					</GotoPairs>
				</NormalBoxNode>
				<NormalBoxNode ID="86" GotoCatchError="-1" Goto="81">
					<OptNodes>
						<AssignNode ID="0" LeftVar="RetryCount" RightExpression="RetryCount-1" />
					</OptNodes>
				</NormalBoxNode>
				<NormalBoxNode ID="90" GotoCatchError="-1" Goto="95">
					<GotoPairs>
						<GotoPair>
							<Expression>ResponseByteData.Slice(3).SequenceEqual(RequestParameter)</Expression>
							<Goto>0</Goto>
						</GotoPair>
					</GotoPairs>
				</NormalBoxNode>
				<NormalBoxNode ID="95" GotoCatchError="-1" Goto="-1">
					<OptNodes>
						<CallFunctionNode ID="0" FunctionName="errorLibrary.SetFault">
							<InputVars>
								<Param>EcuBOMName</Param>
								<Param>ReadErrorVCode</Param>
							</InputVars>
						</CallFunctionNode>
					</OptNodes>
				</NormalBoxNode>

				<!-- NACK -->
				<NormalBoxNode ID="99991" GotoCatchError="-1" Goto="-1">
					<OptNodes>
						<CallFunctionNode ID="0" FunctionName="errorLibrary.SetFault">
							<InputVars>
								<Param>EcuBOMName</Param>
								<Param>"VC0003"</Param>
							</InputVars>
						</CallFunctionNode>
					</OptNodes>
				</NormalBoxNode>
				<!-- Response Timeout -->
				<NormalBoxNode ID="99992" GotoCatchError="-1" Goto="-1">
					<OptNodes>
						<CallFunctionNode ID="0" FunctionName="errorLibrary.SetFault">
							<InputVars>
								<Param>EcuBOMName</Param>
								<Param>"VC0004"</Param>
							</InputVars>
						</CallFunctionNode>
					</OptNodes>
				</NormalBoxNode>

				<NormalBoxNode ID="2147483647" GotoCatchError="-1" Goto="-1">
					<OptNodes>
						<CallFunctionNode ID="2" FunctionName="errorLibrary.SetFault">
							<InputVars>
								<Param>EcuBOMName</Param>
								<Param>"VC0005"</Param>
							</InputVars>
						</CallFunctionNode>
					</OptNodes>
				</NormalBoxNode>
			</FlowsNodes>
		</MainNode>
	</MainNodes>
</TaskNode>
