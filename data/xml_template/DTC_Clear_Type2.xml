<?xml version="1.0"?>
<TaskNode xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:xsd="http://www.w3.org/2001/XMLSchema" ID="0">
	<MainNodes>
		<MainNode ID="0">
			<AnnNode ID="0">
				<CVNodes>
					<CreateVarNode ID="0" Name="SourceAddress"
						Type="Bytes"
						VarDefaultValue="Bytes.Empty" />
					<CreateVarNode ID="1" Name="ECUAddress"
						Type="Bytes"
						VarDefaultValue="Bytes.Empty" />
					<CreateVarNode ID="2" Name="Status"
						Type="EnumRVAgentStatus"
						VarDefaultValue="EnumRVAgentStatus.WaitSend" />
					<CreateVarNode ID="3" Name="ResponseByteData" Type="Bytes"
						VarDefaultValue="Bytes.Empty" />
					<CreateVarNode ID="4" Name="DelayTime" Type="int"
						VarDefaultValue="0" />
					<CreateVarNode ID="5" Name="ModuleName" Type="string"
						VarDefaultValue="string.Empty" />
					<CreateVarNode ID="6" Name="Position" Type="string"
						VarDefaultValue="string.Empty" />
					<CreateVarNode ID="7" Name="Message" Type="string"
						VarDefaultValue="string.Empty" />
				</CVNodes>
			</AnnNode>

			<FlowsNodes>
				<!-- Initial -->
				<NormalBoxNode ID="1" GotoCatchError="-1" Goto="2">
					<OptNodes>
						<AssignNode ID="0" LeftVar="SourceAddress"
							RightExpression="Bytes.Parse(_argLibrary.Get(&quot;SourceAddress&quot;))" />
						<AssignNode ID="1" LeftVar="ECUAddress"
							RightExpression="Bytes.Parse(_argLibrary.Get(&quot;ECUAddress&quot;))" />
						<AssignNode ID="2" LeftVar="ModuleName"
							RightExpression="_argLibrary.Get(&quot;ModuleName&quot;)" />
						<AssignNode ID="3" LeftVar="DelayTime"
							RightExpression="stringLibrary.ToInt(_argLibrary.Get(&quot;DelayTime&quot;))" />
						<AssignNode ID="4" LeftVar="Position"
							RightExpression="_argLibrary.Get(&quot;Position&quot;)" />
						<AssignNode ID="5" LeftVar="Message"
							RightExpression="_argLibrary.Get(&quot;Message&quot;)" />
					</OptNodes>
				</NormalBoxNode>
				<NormalBoxNode ID="2" GotoCatchError="-1" Goto="20">
					<GotoPairs>
						<GotoPair>
							<Expression>!string.IsNullOrEmpty(Position) &amp;&amp; !string.IsNullOrEmpty(Message)</Expression>
							<Goto>3</Goto>
						</GotoPair>
					</GotoPairs>
				</NormalBoxNode>
				<NormalBoxNode ID="3" GotoCatchError="-1" Goto="20">
					<OptNodes>
						<CallFunctionNode ID="1" FunctionName="htmlPageLibrary.SetValue">
							<InputVars>
								<Param Name="key">Position</Param>
								<Param Name="value">Message</Param>
							</InputVars>
						</CallFunctionNode>
					</OptNodes>
				</NormalBoxNode>

				<NormalBoxNode ID="20" GotoCatchError="-1" Goto="21">
					<OptNodes>
						<CallFunctionNode ID="0" FunctionName="_udsLibrary.SendUDSRawData">
							<InputVars>
								<Param>
									Bytes.Concat(SourceAddress,ECUAddress,Bytes.Parse(&quot;0x14FFFFFF&quot;))</Param>
							</InputVars>
						</CallFunctionNode>
					</OptNodes>
				</NormalBoxNode>
				<NormalBoxNode ID="21" GotoCatchError="-1" Goto="23">
					<OptNodes>
						<CallFunctionNode ID="0" RevResultVar="Status" FunctionName="_udsLibrary.ReadStatus" />
					</OptNodes>
				</NormalBoxNode>
				<NormalBoxNode ID="23" GotoCatchError="-1" Goto="0">
					<OptNodes>
						<CallFunctionNode ID="0" FunctionName="fcLibrary.AfterCaseSleep">
							<InputVars>
								<Param>DelayTime</Param>
							</InputVars>
						</CallFunctionNode>
					</OptNodes>
				</NormalBoxNode>
				<NormalBoxNode ID="35" GotoCatchError="-1" Goto="-1">
					<OptNodes>
						<CallFunctionNode ID="0" FunctionName="errorLibrary.SetFault">
							<InputVars>
								<Param>ModuleName</Param>
								<Param>"V32015"</Param>
							</InputVars>
						</CallFunctionNode>
					</OptNodes>
				</NormalBoxNode>

				<NormalBoxNode ID="2147483647" GotoCatchError="-1" Goto="-1">
					<OptNodes>
						<CallFunctionNode ID="2" FunctionName="errorLibrary.SetFault">
							<InputVars>
								<Param>ModuleName</Param>
								<Param>"VC0005"</Param>
							</InputVars>
						</CallFunctionNode>
					</OptNodes>
				</NormalBoxNode>
			</FlowsNodes>
		</MainNode>
	</MainNodes>
</TaskNode>